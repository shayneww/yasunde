{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "yasunde",
  "version": "0.1.0",
  "identifier": "yasunde",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "yasunde",
        "width": 320,
        "height": 210,
        "resizable": false,
        "decorations": false,
        "fullscreen": false,
        "preventOverflow": true,
        "transparent": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": "none"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
        "nsis": {
          "installerIcon": "../public/installer/icon.ico",
          "sidebarImage": "../public/installer/sidebarImage.bmp"
        }
      }
  }
}